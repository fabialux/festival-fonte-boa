generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Torcedor {
  id        Int      @id @default(autoincrement())
  nome      String
  cidade    String
  cpf       String   @unique
  boi       String
  createdAt DateTime @default(now())
}